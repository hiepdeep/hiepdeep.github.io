{
	"manifest_version": 3,
	"name": "Custom CSS Injector",
	"version": "1.0",
	"description": "Tuỳ chỉnh và lưu CSS cho bất kỳ trang web nào.",
	"permissions": ["storage", "activeTab", "tabs"],
	"host_permissions": ["<all_urls>"],
	"action": {
		"default_title": "CSS Custom Editor",
		"default_icon": {
			"16": "css-16.png",
			"48": "css-48.png",
			"128": "css-128.png"
		}
	},
	"icons": {
		"16": "css-16.png",
		"48": "css-48.png",
		"128": "css-128.png"
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [{
		"matches": ["<all_urls>"],
		"js": ["content.js"],
		"run_at": "document_start"
	}]
}